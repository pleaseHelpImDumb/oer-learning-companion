generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model User {
  userId Int @id @default(autoincrement())
  role Role @default(STUDENT)
  email String @unique
  password String // hashed with bcrypt
  username String
  avatarUrl String @default("assets/profiles/profile0.png")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetPasswordToken     String?  @unique
  resetPasswordExpires   DateTime?

  // Student
  nickname String?
  checkinIntervalMinutes Int @default(5)
  favoriteQuote String?
  onboardingCompleted Boolean @default(false)
  yearLevel StudentYear @default(FRESHMAN)
  major String?

  trackId Int?
  track HobbyTrack? @relation(fields:[trackId], references: [trackId])

  // For Backwards Reference
  studySessions StudySession[]
  userBadges UserBadge[]
  userStats UserStats?
}

model HobbyTrack {
  trackId Int @id @default(autoincrement())
  name String @unique
  description String
  iconUrl String

  users User[]
}

model Badge {
  badgeId Int @id @default(autoincrement())
  name String @unique
  description String
  type BadgeType
  thresholdValue Int?
  iconUrl String

  userBadges UserBadge[]
}

model UserBadge {
  userId Int
  badgeId Int
  unlockedAt DateTime @default(now())

  // Foreign Keys
  user User @relation(fields:[userId], references: [userId])
  badge Badge @relation(fields:[badgeId], references: [badgeId])

  @@id([userId, badgeId]) // comp primary key
}

model UserStats {
  userId Int @id
  totalStudyMinutes Int @default(0)
  totalSessions Int @default(0)
  currentStreakLength Int @default(0)
  longestStreakLength Int @default(0)
  lastSessionDate DateTime?
  totalAiInteractions Int @default(0)
  totalWellnessChecks Int @default(0)
  totalTokensEarned Int @default(0)

  user User @relation(fields:[userId], references:[userId])
}

model StudySession {
  sessionId Int @id @default(autoincrement())
  userId Int
  
  status SessionStatus @default(ACTIVE)
  startTime DateTime @default(now())
  endTime DateTime?
  lastPauseTime DateTime?
  totalPausedMinutes Int @default(0)
  durationMinutes Int? //set on completed
  numAiInteractions Int @default(0)
  tokensSpent Int @default(0)
  group Group?
  notes String?

  // Foreign Keys
  user User @relation(fields:[userId], references:[userId])

  aiInteractions AIInteraction[]
  wellnessChecks WellnessCheck[]
}

model AIInteraction {
  aiInteractionId Int @id @default(autoincrement())
  sessionId Int
  role AIRole
  createdAt DateTime @default(now())
  message String
  supportLevel Int @default(1)

  session StudySession @relation(fields:[sessionId], references:[sessionId])
}

// ADD WELLNESS/CHECK-IN TABLE
model WellnessCheck {
  wellnessCheckId Int @id @default(autoincrement())
  sessionId Int
  createdAt DateTime @default(now())
  feelingGood Boolean
  helpChosen String

  session StudySession @relation(fields:[sessionId], references:[sessionId])
}

enum AIRole {
  USER
  AI
}

enum Role {
  STUDENT
  ADMIN
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum StudentYear {
  FRESHMAN
  SOPHOMORE
  JUNIOR
  SENIOR
}

enum Group {
  CONTROL
  TREATMENT
}

enum BadgeType{
  TOTAL_TIME
  SESSION_COUNT
  STREAK
  MILESTONE
}