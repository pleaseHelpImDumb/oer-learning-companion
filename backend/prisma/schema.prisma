generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

/*
This week's changes:

USER: add yearLevel (FRESHMAN, SOPHOMORE...), Major ("Comp Sci","Biology")
STUDYSESSION: add numAiInteractions (not strictly needed, but if purging AIINTERACTION table it's nice) and group (CONTROL, TREATMENT (from document sent this morning))
AIINTERACTION: add supportLevel (1, 2, 3, any other options)

*/
model User {
  userId Int @id @default(autoincrement())
  role Role @default(STUDENT)
  email String @unique
  password String // hashed with bcrypt
  username String
  avatarUrl String @default("assets/profiles/profile0.png")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetPasswordToken     String?  @unique
  resetPasswordExpires   DateTime?

  // Student
  tokenBalance Int @default(0)
  nickname String?
  checkinIntervalMinutes Int @default(5)
  favoriteQuote String?
  onboardingCompleted Boolean @default(false)
  yearLevel StudentYear @default(FRESHMAN)
  major String?

  trackId Int?
  track HobbyTrack? @relation(fields:[trackId], references: [trackId])

  // For Backwards Reference
  studySessions StudySession[]
  userBadges UserBadge[]
}

model HobbyTrack {
  trackId Int @id @default(autoincrement())
  name String @unique
  description String
  iconUrl String

  users User[]
}

model Badge {
  badgeId Int @id @default(autoincrement())
  name String @unique
  description String
  category String
  iconUrl String

  userBadges UserBadge[]
}

model UserBadge {
  userId Int
  badgeId Int
  unlockedAt DateTime @default(now())

  // Foreign Keys
  user User @relation(fields:[userId], references: [userId])
  badge Badge @relation(fields:[badgeId], references: [badgeId])

  @@id([userId, badgeId]) // comp primary key
}

model StudySession {
  sessionId Int @id @default(autoincrement())
  userId Int
  
  status SessionStatus @default(ACTIVE)
  startTime DateTime @default(now())
  endTime DateTime?
  lastPauseTime DateTime?
  totalPausedMinutes Int @default(0)
  durationMinutes Int? //set on completed
  numAiInteractions Int @default(0)
  group Group?
  notes String?
  
  // Foreign Keys
  user User @relation(fields:[userId], references:[userId])

  aiInteractions AIInteraction[]
}

model AIInteraction {
  aiInteractionId Int @id @default(autoincrement())
  sessionId Int
  role AIRole
  createdAt DateTime @default(now())
  message String
  supportLevel Int @default(1)

  session StudySession @relation(fields:[sessionId], references:[sessionId])
}

enum AIRole {
  USER
  AI
}

enum Role {
  STUDENT
  ADMIN
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum StudentYear {
  FRESHMAN
  SOPHOMORE
  JUNIOR
  SENIOR
}

enum Group {
  CONTROL
  TREATMENT
}